generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl= env("DIRECT_URL")
}

model User {
  id                  String                   @id @default(cuid())
  name                String?
  email               String?                  @unique
  passwordHash        String?
  role                Role                     @default(USER)
  kycStatus           KycStatus                @default(NONE)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  phoneNumber         String?                  @unique
  username            String?                  @unique
  emailVerified       DateTime?
  image               String?
  accounts            Account[]
  kycSubmission       KycSubmission?
  properties          Property[]
  notifications       Notification[]
  propertyBoosts      PropertyBoost[]
  sessions            Session[]
  criteriaWeights     UserCriteriaWeight[]
  personalization     UserPersonalization?
  preferredFacilities UserPreferenceFacility[]
  conversationAsUser  Conversation[]           @relation("ConversationUser")
  conversationAsOwner Conversation[]           @relation("ConversationOwner")
  sentMessages        Message[]                @relation("MessageSender")
  boostCart BoostCart[]
  bookmarks Bookmark[]
  reviews   Review[]
  reviewReplies ReviewReply[]
  boostPayments BoostPayment[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model KycSubmission {
  id             String    @id @default(cuid())
  userId         String    @unique
  ktpImageUrl    String
  status         KycStatus @default(PENDING)
  adminNotes     String?
  reviewedBy     String?
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  cityOrRegency  String
  district       String
  fullName       String
  nik            String
  phoneNumber    String
  postalCode     String
  province       String
  rt             String
  rw             String
  selfieImageUrl String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Property {
  id          String             @id @default(cuid())
  ownerId     String
  title       String
  category    PropertyCategory   @default(RUMAH)
  address     String?
  city        String?
  district    String?
  neighbourhood String?
  latitude    Float?
  longitude   Float?
  imageUrls   String[]           @default([])
  description String?
  price       Decimal
  listingType String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  owner       User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  facilities  PropertyFacility[]
  boosts      PropertyBoost[]
  boostPaymentItems BoostPaymentItem[]
  boostCart   BoostCart[]
  bookmarks   Bookmark[]
  reviews   Review[]
  conversations Conversation[]
}

model Notification {
  id        String   @id @default(cuid())
  ownerId   String
  title     String
  message   String
  imageUrl  String?         
  isRead    Boolean  @default(false)
  type      String
  createdAt DateTime @default(now())
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, createdAt])
}

model PropertyBoost {
  id           String   @id @default(cuid())
  paymentId    String?
  propertyId   String
  ownerId      String
  packageId    String
  packageTitle String
  days         Int
  price        Int
  startsAt     DateTime @map("start_date")
  endsAt       DateTime @map("end_date")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  payment  BoostPayment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  owner    User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([propertyId, endsAt])
  @@index([ownerId, endsAt])
}

model Facility {
  id          String                   @id @default(cuid())
  code        String                   @unique
  name        String                   @unique
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  properties  PropertyFacility[]
  preferredBy UserPreferenceFacility[]
}

model PropertyFacility {
  propertyId String
  facilityId String
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@id([propertyId, facilityId])
  @@index([facilityId])
}

model UserPreferenceFacility {
  userId     String
  facilityId String
  isRequired Boolean  @default(false)
  weight     Float    @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, facilityId])
  @@index([facilityId])
}

model UserCriteriaWeight {
  id        String      @id @default(cuid())
  userId    String
  criteria  DssCriteria
  weight    Float       @default(1)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, criteria])
  @@index([userId])
}

model UserPersonalization {
  id                    String   @id @default(cuid())
  userId                String   @unique
  location              String?
  occupation            String?
  budgetMin             Int?
  budgetMax             Int?
  gender                String?
  prefFurnished         Boolean  @default(false)
  prefUnfurnished       Boolean  @default(false)
  prefPetFriendly       Boolean  @default(false)
  prefParkirMobil       Boolean  @default(false)
  prefAc                Boolean  @default(false)
  prefWaterHeater       Boolean  @default(false)
  prefDekatTransportasi Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  USER
  OWNER
  ADMIN
}

enum KycStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum DssCriteria {
  BUDGET
  LOCATION
  FACILITIES
  GENDER
}

enum PropertyCategory {
  RUMAH
  APARTEMEN
  KOSAN
}

enum BoostPaymentProvider {
  MIDTRANS
}

enum BoostPaymentStatus {
  PENDING
  PROCESSING
  PAID
  EXPIRED
  FAILED
  CANCELLED
}

model BoostPayment {
  id                    String              @id @default(cuid())
  orderId               String              @unique
  ownerId               String
  provider              BoostPaymentProvider @default(MIDTRANS)
  status                BoostPaymentStatus   @default(PENDING)
  paymentMethod         String?
  paymentType           String?
  subtotal              Int
  adminFee              Int                 @default(0)
  grossAmount           Int
  providerTransactionId String?             @unique
  snapToken             String?
  redirectUrl           String?
  rawRequest            Json?
  rawResponse           Json?
  settledAt             DateTime?
  expiredAt             DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  owner  User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  items  BoostPaymentItem[]
  boosts PropertyBoost[]

  @@index([ownerId, createdAt])
  @@index([status, createdAt])
}

model BoostPaymentItem {
  id            String       @id @default(cuid())
  paymentId     String
  propertyId    String
  propertyTitle String
  packageId     String
  packageTitle  String
  days          Int
  price         Int
  createdAt     DateTime     @default(now())

  payment  BoostPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  property Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([propertyId])
}

model BoostCart {
  id           String   @id @default(cuid())
  ownerId      String
  propertyId   String
  packageId    String
  packageTitle String
  days         Int
  price        Int
  createdAt    DateTime @default(now())

  owner    User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([propertyId])
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])  // 1 user tidak bisa bookmark properti yang sama 2x
}

model Review {
  id         String        @id @default(cuid())
  userId     String
  propertyId String
  rating     Int          
  comment    String?
  imageUrls  String[]      @default([])
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  replies  ReviewReply[]

  @@unique([userId, propertyId]) 
  @@index([propertyId, createdAt])
  @@index([userId])
}

model ReviewReply {
  id        String   @id @default(cuid())
  reviewId  String
  ownerId   String
  comment   String   @db.Text
  createdAt DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  owner  User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@index([ownerId])
}

model Conversation {
  id         String    @id @default(cuid())
  propertyId String
  userId     String
  ownerId    String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  property   Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User      @relation("ConversationUser", fields: [userId], references: [id], onDelete: Cascade)
  owner      User      @relation("ConversationOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  messages   Message[]

  @@unique([propertyId, userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
}